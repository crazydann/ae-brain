# ──────────────────────────────────────────
# AE Brain Dashboard 환경변수
# .env.local 파일로 복사 후 값 입력
# ──────────────────────────────────────────

# Supabase (기존 프로젝트 재사용 가능 - ae_ 접두사 테이블 사용)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Glean (기업 검색 - Gmail/Slack/Calendar 통합)
# Settings → API Tokens에서 발급
GLEAN_INSTANCE_URL=https://yourcompany-be.glean.com
GLEAN_API_TOKEN=your-glean-api-token

# JWT 세션 시크릿 (32자 이상 임의 문자열)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ──────────────────────────────────────────
# OpenAI/Anthropic API 키 불필요
# 모든 AI 분석은 Claude Code가 직접 수행 후 Supabase에 저장
# ──────────────────────────────────────────
